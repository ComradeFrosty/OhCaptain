{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ohcaptain",
  "version": "0.1.0",
  "identifier": "com.saaro.ohcaptain",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Whisper",
    "width": 380,
    "height": 160,
    "resizable": false,
    "fullscreen": false,
    "transparent": true,
    "decorations": false,
    "alwaysOnTop": false,
    "x": 1120,
    "y": 20
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
